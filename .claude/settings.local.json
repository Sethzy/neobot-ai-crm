{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)",
      "WebFetch(domain:eservice.ura.gov.sg)",
      "WebFetch(domain:ai-sdk.dev)",
      "WebSearch",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(lsof -i :3000 -sTCP:LISTEN)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_console_messages",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "mcp__playwright__browser_click",
      "Bash(node -e \"const rp = require\\('react-resizable-panels'\\); console.log\\('usePanelRef' in rp, typeof rp.usePanelRef\\)\")",
      "Bash(node -e ':*)",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_run_code",
      "Bash(node -e \"console.log\\(require\\('react-resizable-panels/package.json'\\).version\\)\")",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "sunder"
  ],
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude finished\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  }
}
