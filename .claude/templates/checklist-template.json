        "User linked to {client-id} config in user_profiles",
        "Assignment verified via join query"
      ],
      "passes": false
    },
    {
      "category": "phase_8_e2e_testing",
      "description": "Phase 8: End-to-End Testing (MANUAL CHECKPOINT)",
      "core_feature": "client_onboarding",
      "phase_number": 8,
      "is_manual": true,
      "checkpoint_message": "🛑 CHECKPOINT: QA testing with test documents from src/clients/{client-id}/test-docs/",
      "test_scenarios": [
        {
          "scenario": "Happy path - Clean doc, all fields present",
          "validations": [
            "Status: complete ✅",
            "No validation errors ✅",
            "No low confidence warnings ✅"
          ]
        },
        {
          "scenario": "Missing required field - Triggers validation",
          "validations": [
            "Status: needs_review ✅",
            "Validation error displayed ✅",
            "Error mentions missing field ✅"
          ]
        },
        {
          "scenario": "Low quality scan - Flags confidence issues",
          "validations": [
            "Status: needs_review ✅",
            "Low confidence fields highlighted ✅",
            "Confidence scores visible ✅"
          ]
        },
        {
          "scenario": "Multi-type PDF - Splits correctly",
          "validations": [
            "Multiple splits created ✅",
            "Each split tagged correctly ✅",
            "Each split extracted independently ✅"
          ]
        },
        {
          "scenario": "Unknown document - Classifies as 'other'",
          "validations": [
            "Tagged as 'other' ✅",
            "No extraction attempted ✅"
          ]
        }
      ],
      "steps": [
        "Test scenario: Happy path - Clean doc, all fields present",
        "Test scenario: Missing required field - Triggers validation",
        "Test scenario: Low quality scan - Flags confidence issues",
        "Test scenario: Multi-type PDF - Splits correctly",
        "Test scenario: Unknown document - Classifies as 'other'",
        "Database verification: schema_version shows 1.0.0",
        "Database verification: All tags match config"
      ],
      "database_verification_query": "SELECT d.original_filename, s.tag_id, s.extraction_status, s.schema_version FROM splits s JOIN documents d ON s.document_id = d.id WHERE d.created_by = '{user_uuid}' ORDER BY d.created_at DESC LIMIT 10;",
      "passes": false
    },
    {
      "category": "phase_9_optimization",
      "description": "Phase 9: Optimization (OPTIONAL)",
      "core_feature": "client_onboarding",
      "phase_number": 9,
      "is_manual": true,
      "is_optional": true,
      "steps": [
        "Evaluation set created (20-30+ docs)",
        "Ground truth manually verified",
        "Composer optimization run",
        "Optimized schemas pulled to codebase",
        "Version bumped (e.g., v1.0.0 → v1.1.0)"
      ],
      "passes": false
    }
