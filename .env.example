# Supabase (public keys used by browser + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Separate property-data Supabase project (public read-only)
NEXT_PUBLIC_PROPERTY_SUPABASE_URL=
NEXT_PUBLIC_PROPERTY_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://www.trysunder.com
NEXT_PUBLIC_APP_URL=https://app.trysunder.com

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=phc_7S4UAyLFmXL9x9qgqWN6oTpKDQhwvPhYEdV7CaS0hxE
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional backward-compatible aliases
SUPABASE_URL=
SUPABASE_ANON_KEY=
PROPERTY_SUPABASE_URL=
PROPERTY_SUPABASE_ANON_KEY=

# Supabase server-only key
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# AI providers
AI_GATEWAY_API_KEY=
GROQ_API_KEY=
COMPOSIO_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
EXTEND_API_KEY=
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
GOOGLE_MAPS_API_KEY=

# Redis (required for resumable chat streams)
REDIS_URL=

# Internal and webhook integrations
SUNDER_INTERNAL_SECRET=
OPENCLAW_CALLBACK_URL=
WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_MAX_PRICE_ID=

# Browser-Use Cloud (browser automation — SERVICE-12)
BROWSER_USE_API_KEY=

# Sandbox model routing via OpenRouter (PR 54)
# When set, sandbox Claude CLI routes through OpenRouter instead of Anthropic direct.
# See: https://openrouter.ai/docs/guides/coding-agents/claude-code-integration
OPENROUTER_API_KEY=

# Optional: override the model used in sandbox tasks.
# Examples: minimax/minimax-m2.7, minimax/minimax-m1, google/gemini-2.5-flash, anthropic/claude-sonnet-4-6
# Only used when OPENROUTER_API_KEY is set.
SANDBOX_MODEL_ID=

# Async sandbox job webhook callback auth (HMAC signing secret)
SANDBOX_CALLBACK_SECRET=

# ── Vercel Sandbox ──────────────────────────────────────────
# On Vercel: OIDC auth is automatic, no vars needed
# Local dev: set VERCEL_TOKEN + VERCEL_TEAM_ID + VERCEL_PROJECT_ID
VERCEL_OIDC_TOKEN=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
# Required only when sandbox features (bash tool) are used
SANDBOX_GOLDEN_SNAPSHOT_ID=

# Sentry error tracking (PR 47e)
# Use the same DSN for both server and client.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
