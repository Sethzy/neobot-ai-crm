# Supabase (public keys used by browser + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Separate property-data Supabase project (public read-only)
NEXT_PUBLIC_PROPERTY_SUPABASE_URL=
NEXT_PUBLIC_PROPERTY_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://www.trysunder.com
NEXT_PUBLIC_APP_URL=https://app.trysunder.com
# Optional: public Brandfetch client ID for richer company logos in search.
# When omitted, the app falls back to Google favicons and initials.
NEXT_PUBLIC_BRANDFETCH_CLIENT_ID=

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional backward-compatible aliases
SUPABASE_URL=
SUPABASE_ANON_KEY=
PROPERTY_SUPABASE_URL=
PROPERTY_SUPABASE_ANON_KEY=

# Supabase server-only key
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Optional local integration test overrides.
# When omitted, tests read local credentials from `supabase status -o env`.
SUPABASE_LOCAL_URL=http://127.0.0.1:54321
SUPABASE_LOCAL_ANON_KEY=
SUPABASE_LOCAL_SERVICE_ROLE_KEY=
SUPABASE_LOCAL_JWT_SECRET=

# AI providers
AI_GATEWAY_API_KEY=
GROQ_API_KEY=
COMPOSIO_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
EXTEND_API_KEY=
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
GOOGLE_MAPS_API_KEY=
# xAI Grok Speech-to-Text (meeting transcription)
XAI_API_KEY=

# Redis (required for resumable chat streams)
REDIS_URL=

# Internal and webhook integrations
SUNDER_INTERNAL_SECRET=
OPENCLAW_CALLBACK_URL=
WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_MAX_PRICE_ID=

# Browser-Use Cloud (browser automation — SERVICE-12)
BROWSER_USE_API_KEY=

# Sentry error tracking (PR 47e)
# Use the same DSN for both server and client.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
